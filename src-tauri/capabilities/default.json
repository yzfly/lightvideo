{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "主窗口权限: 对话框 + ffmpeg/ffprobe/sherpa-asr sidecar + curl(模型下载)",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "dialog:default",
    "shell:allow-kill",
    {
      "identifier": "shell:allow-spawn",
      "allow": [
        { "name": "binaries/ffmpeg", "sidecar": true, "args": true },
        { "name": "binaries/ffprobe", "sidecar": true, "args": true },
        { "name": "binaries/sherpa-asr", "sidecar": true, "args": true },
        { "name": "curl", "cmd": "curl", "args": true }
      ]
    },
    {
      "identifier": "shell:allow-execute",
      "allow": [
        { "name": "binaries/ffmpeg", "sidecar": true, "args": true },
        { "name": "binaries/ffprobe", "sidecar": true, "args": true },
        { "name": "binaries/sherpa-asr", "sidecar": true, "args": true },
        { "name": "curl", "cmd": "curl", "args": true }
      ]
    }
  ]
}
